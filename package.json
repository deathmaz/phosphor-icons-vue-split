{
  "name": "phosphor-icons-vue-split",
  "version": "0.1.0",
  "description": "Phosphor Icons for Vue 3 with per-weight components for optimal tree-shaking",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "types": "dist/index.d.ts",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "assemble": "tsx bin/assemble.ts",
    "generate-types": "tsx bin/generate-types.ts",
    "build": "rimraf dist && npm run assemble && vite build && npm run generate-types",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "check": "npm run typecheck && npm run lint"
  },
  "peerDependencies": {
    "vue": ">=3.2.39"
  },
  "devDependencies": {
    "@phosphor-icons/core": "^2.1.1",
    "@types/node": "^25.3.2",
    "@vitejs/plugin-vue": "^6.0.0",
    "oxlint": "^1.50.0",
    "rimraf": "^5.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0"
  }
}
